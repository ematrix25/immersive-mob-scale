{
	"schemaVersion": 1,
	"id": "immersivemobscale",
	"version": "${version}",
	"name": "Immersive Mob Scale",
	"description": "This is a mod for a more immersive scale of mobs to make creature proportions more realistic.",
	"authors": [
		"ematrix25"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/immersivemobscale/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ematrix25.immersivemobscale.Main"
		],
		"client": [
			"com.ematrix25.immersivemobscale.Client"
		]
	},
	"mixins": [
		"immersivemobscale.mixins.json",
		{
			"config": "immersivemobscale.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}